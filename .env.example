WEREWOLF_LLM_API_KEY=your-api-key
WEREWOLF_LLM_BASE_URL=https://router.shengsuanyun.com/api/v1
WEREWOLF_LLM_MODEL=ali/qwen3.5-flash
WEREWOLF_LLM_TIMEOUT=45
WEREWOLF_LLM_TEMPERATURE=0.4
WEREWOLF_LLM_THINKING=disabled

# Optional LLM retry/circuit tuning. Defaults are conservative; raise them only
# when the provider has transient failures and extra latency is acceptable.
WEREWOLF_LLM_MAX_RETRIES=0
WEREWOLF_LLM_RETRY_INITIAL_DELAY=1.0
WEREWOLF_LLM_RETRY_MAX_DELAY=30.0
WEREWOLF_LLM_RUNTIME_MAX_ATTEMPTS=1
WEREWOLF_LLM_RUNTIME_RETRY_INITIAL_DELAY=0.25
WEREWOLF_LLM_RUNTIME_RETRY_MAX_DELAY=2.0
WEREWOLF_LLM_RUNTIME_CIRCUIT_FAILURES=3
WEREWOLF_LLM_RUNTIME_CIRCUIT_COOLDOWN=30.0

# 设置页写入权限。生产环境请生成强随机 token，并只在服务端环境变量中保存。
SETTINGS_ADMIN_ENABLED=false
SETTINGS_ADMIN_TOKEN=
# 模型 Profile 会加密保存 API Key；启用模型 Profile 写入时必须配置并保持稳定。
# 示例生成：openssl rand -hex 32
SETTINGS_SECRET_ENCRYPTION_KEY=
SETTINGS_SECRET_ENCRYPTION_KEY_ID=settings:v1

# Runtime guardrails and task execution. Values set here override the Settings
# page runtime-variable store.
TASK_WORKER_REQUIRED=true
UI_BACKGROUND_REFRESH_INTERVAL_SECONDS=10
WOLF_USE_PG_TASK_QUEUE=true
WEREWOLF_GAME_CONCURRENCY=4
BENCHMARK_ROLE_CONCURRENCY=2
WEREWOLF_EVOLUTION_ROLE_CONCURRENCY=2
# Per-kind global limits shared by all PostgreSQL task workers.
UI_TASK_KIND_CONCURRENCY_LIMITS={"benchmark_batch":1,"evolution_batch":1,"evolution_run":1}
# Coalesce high-frequency background snapshots while always flushing terminal states.
UI_BACKGROUND_PERSIST_INTERVAL_SECONDS=1
WEREWOLF_JUDGE_CONCURRENCY=6
WEREWOLF_LLM_MAX_CONCURRENCY=8
WEREWOLF_RUNNER_MAX_RETRIES=3
WEREWOLF_RUNNER_RETRY_DELAY=0
WEREWOLF_GAME_TIMEOUT=900
WEREWOLF_BATCH_GAME_TIMEOUT=900
HEALTH_LLM_PROBE_TTL_SECONDS=300
HEALTH_LLM_PROBE_FAILURE_TTL_SECONDS=60
HEALTH_PAYLOAD_TTL_SECONDS=1
# Compatibility aliases accepted by older runner paths; prefer the keys above.
# WEREWOLF_RUNNER_GAME_TIMEOUT=900
# WEREWOLF_RUNNER_BATCH_GAME_TIMEOUT=900

# PostgreSQL is the only supported runtime storage backend.
# If PostgreSQL is only reachable on the server's loopback interface, keep an
# SSH tunnel open, for example:
#   ssh -L 15432:127.0.0.1:5432 deploy@example.com
# Docker Compose uses these values for the bundled PostgreSQL container and
# published HTTP ports. Change POSTGRES_PASSWORD before any non-local deploy.
POSTGRES_DB=wolf_app
POSTGRES_USER=wolf_app
POSTGRES_PASSWORD=wolf_password
APP_PORT=8080
API_PORT=8000
POSTGRES_DATABASE_URL=postgresql://wolf_app:password@127.0.0.1:5432/wolf_app
# DATABASE_URL is kept for tools that read the generic name.
DATABASE_URL=${POSTGRES_DATABASE_URL}
PG_POOL_MIN_SIZE=1
PG_POOL_MAX_SIZE=10
# Set false for local development against a remote database to avoid one extra
# round trip every time a pooled connection is borrowed.
PG_POOL_CHECK_CONNECTION=true
POSTGRES_DISABLE_DOTENV=false

# 玩家发言朗读，使用 DashScope Qwen realtime TTS。
WEREWOLF_TTS_API_KEY=your-dashscope-api-key
WEREWOLF_TTS_MODEL=qwen3-tts-flash-realtime
WEREWOLF_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
WEREWOLF_TTS_VOICE=Cherry
WEREWOLF_TTS_VOICE_POOL=
WEREWOLF_TTS_SAMPLE_RATE=24000
WEREWOLF_TTS_MODE=server_commit
WEREWOLF_TTS_TIMEOUT=60
WEREWOLF_TTS_MAX_CHARS=320
WEREWOLF_TTS_STYLE=自然、清晰、有临场感的中文狼人杀玩家发言，语速适中，情绪克制但有辨识度。

# Backend / frontend local development. 前端只放开关和 API 地址，不放密钥。
UI_BACKEND_USE_FAKE_LLM=false
UI_BACKEND_ROOT=
UI_FRONTEND_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_BASE=/api
VITE_USE_FRONTEND_MOCK=false
VITE_TTS_ENABLED=true
VITE_TTS_MAX_CHARS=260
VITE_TTS_INCLUDE_SPEAKER=true

# Release metadata exposed in health/ops payloads.
WOLF_APP_RELEASE=local-dev
WOLF_APP_ENVIRONMENT=local
WOLF_GIT_SHA=

# 可选链路追踪，面向自部署 Langfuse。
# 开启 LANGFUSE_TRACING_ENABLED=true 时，下面这些变量都要配置，状态才不会显示“降级”。
# LANGFUSE_BASE_URL 必须指向你的自部署 Langfuse 服务，不使用官方 cloud 默认值。
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=http://127.0.0.1:3000
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=local-dev
LANGFUSE_SAMPLE_RATE=1.0
# Tracing 默认关闭；如果把 LANGFUSE_TRACING_ENABLED 改为 true，
# 保持这里为 true 才不会出现 Input null / Output undefined 或健康降级。
# 生产开启前请确认 prompt/response 数据已经过审查和脱敏。
LANGFUSE_CAPTURE_INPUT_OUTPUT=false
LANGFUSE_PROMPT_MANAGEMENT_ENABLED=false
LANGFUSE_PROMPT_LABEL=production

# Advanced agent smoke/prompt/memory controls. Usually leave unset; these are
# mainly for fast local smoke runs and prompt-budget experiments.
# WEREWOLF_AGENT_FAST_SMOKE=false
# WEREWOLF_AGENT_POLICY_SKIP_LLM_ENABLED=false
# WEREWOLF_AGENT_POLICY_SKIP_LLM_PRESET=
# WEREWOLF_AGENT_POLICY_SKIP_LLM_ACTIONS=
# WEREWOLF_AGENT_MEMORY_COMPRESSION_ENABLED=true
# WEREWOLF_AGENT_PROMPT_MAX_TOTAL_CHARS=
# WEREWOLF_AGENT_PROMPT_MAX_MESSAGE_CHARS=
# WEREWOLF_AGENT_PROMPT_MIN_MESSAGE_CHARS=
# WEREWOLF_AGENT_MEMORY_RECENT_CLOSED_SEGMENTS=
# WEREWOLF_AGENT_MEMORY_MAX_EVENTS_PER_SEGMENT=
# WEREWOLF_AGENT_MEMORY_EVENT_MAX_CHARS=
