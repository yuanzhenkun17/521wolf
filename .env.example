WEREWOLF_LLM_API_KEY=your-api-key
WEREWOLF_LLM_BASE_URL=https://router.shengsuanyun.com/api/v1
WEREWOLF_LLM_MODEL=ali/qwen3.5-flash
WEREWOLF_LLM_TIMEOUT=45
WEREWOLF_LLM_TEMPERATURE=0.4

# PostgreSQL is the only supported runtime storage backend.
# If PostgreSQL is only reachable on the server's loopback interface, keep an
# SSH tunnel open, for example:
#   ssh -L 15432:127.0.0.1:5432 deploy@example.com
POSTGRES_DATABASE_URL=postgresql://wolf_app:password@127.0.0.1:5432/wolf_app
# DATABASE_URL is kept for tools that read the generic name.
DATABASE_URL=${POSTGRES_DATABASE_URL}

# 玩家发言朗读后端代理。
WEREWOLF_TTS_API_KEY=your-tts-api-key
WEREWOLF_TTS_BASE_URL=https://api.xiaomimimo.com/v1
WEREWOLF_TTS_MODEL=mimo-v2.5-tts
WEREWOLF_TTS_FORMAT=wav
WEREWOLF_TTS_VOICE=mimo_default
WEREWOLF_TTS_TIMEOUT=60
WEREWOLF_TTS_MAX_CHARS=320
WEREWOLF_TTS_AUTH_HEADER=api-key
WEREWOLF_TTS_STYLE=自然、清晰、有临场感的中文狼人杀玩家发言，语速适中，情绪克制但有辨识度。

# 前端只放朗读开关，不放密钥。
VITE_TTS_ENABLED=true
VITE_TTS_MAX_CHARS=260
VITE_TTS_INCLUDE_SPEAKER=true

# 可选链路追踪，面向自部署 Langfuse。两个密钥都配置后才会启用。
# LANGFUSE_BASE_URL 必须指向你的自部署 Langfuse 服务，不使用官方 cloud 默认值。
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://127.0.0.1:3000
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=
LANGFUSE_SAMPLE_RATE=1.0
LANGFUSE_CAPTURE_INPUT_OUTPUT=false
