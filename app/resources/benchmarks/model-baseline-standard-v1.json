{
  "id": "model-baseline-standard-v1",
  "version": 1,
  "name": "Model Baseline Standard Benchmark",
  "description": "Fixed-seed full-role benchmark for model/runtime comparison.",
  "target_type": "model",
  "roles": ["villager", "seer", "witch", "hunter", "guard", "werewolf", "white_wolf_king"],
  "game_count": 30,
  "max_days": 5,
  "paired_seed": true,
  "seed_set_id": "model-baseline-standard-202606",
  "seed_start": 271000,
  "metrics": {
    "primary": "strength_score",
    "secondary": [
      "avg_role_score",
      "villagers_win_rate",
      "werewolves_win_rate",
      "fallback_rate",
      "llm_error_rate",
      "policy_adjusted_rate",
      "decision_judge_avg_score"
    ]
  },
  "gates": {
    "min_completed_games": 20,
    "min_valid_game_rate": 0.8,
    "max_fallback_rate": 0.25,
    "max_llm_error_rate": 0.15,
    "max_policy_adjusted_rate": 0.25
  },
  "judge": {
    "enable_decision_judge": true,
    "judge_max_decisions": 20,
    "judge_concurrency": 6,
    "judge_timeout_seconds": 60
  },
  "enabled": true,
  "cost_tier": "standard"
}
