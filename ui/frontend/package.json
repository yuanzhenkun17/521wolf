{
  "name": "ai-werewolf-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit && vue-tsc --noEmit -p tsconfig.vitest.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run test:unit && npm run test:component",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:e2e:smoke": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "preview": "vite preview --host 127.0.0.1",
    "serve": "python serve_static.py"
  },
  "dependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "echarts": "^5.6.0",
    "pinia": "^3.0.4",
    "three": "^0.184.0",
    "vite": "^6.0.7",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  }
}
